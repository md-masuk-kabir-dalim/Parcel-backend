model Parcel {
    id                  String        @id @default(uuid())
    code                String        @unique
    customer            User          @relation("CustomerParcels", fields: [customerId], references: [id])
    customerId          String
    agent               User?         @relation("AgentParcels", fields: [agentId], references: [id])
    agentId             String?
    pickupLocation      Json
    dropoffLocation     Json
    pickupContactName   String?
    pickupContactPhone  String?
    dropoffContactName  String?
    dropoffContactPhone String?
    type                String?
    weight              Float?
    sizeCategory        String?
    paymentMode         PAYMENT_MODE
    codAmount           Float?        @default(0)
    deliveryFee         Float?        @default(0)
    totalAmount         Float?        @default(0)
    status              PARCEL_STATUS @default(UNASSIGNED)
    failedReason        String?
    assignedAt          DateTime?
    assignedBy          String?
    deliveredAt         DateTime?
    createdAt           DateTime      @default(now())
    updatedAt           DateTime      @updatedAt

    @@index([customerId])
    @@index([agentId])
    @@index([status])
    @@index([type])
    @@index([createdAt])
    @@index([updatedAt])
    @@map("parcels")
}

enum PAYMENT_MODE {
    COD
    PREPAID
}

enum PARCEL_STATUS {
    UNASSIGNED
    ASSIGNED
    PICKED_UP
    IN_TRANSIT
    DELIVERED
    FAILED
}
